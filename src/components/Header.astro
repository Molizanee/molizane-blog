---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import LanguageSelect from "./LanguageSelect.astro";
---

<header>
	<nav>
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="main-nav">
			<HeaderLink href="/" data-i18n="nav.home">Home</HeaderLink>
			<HeaderLink href="/about" data-i18n="nav.about">About</HeaderLink>
			<HeaderLink href="/projects" data-i18n="nav.projects">Projects</HeaderLink
			>
		</div>
		<div
			class="action-link"
			style="display: flex; gap: 1em; align-items: center;"
		>
			<a href="https://github.com/Molizanee" target="_blank"
				>GitHub <span class="arrow">-&gt;</span></a
			>
			<LanguageSelect />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 1.5em 2em;
		background: var(--bg-color);
		border-bottom: 1px solid var(--grid-line);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
	}
	.brand a {
		font-family: var(--font-mono);
		font-size: 0.9em;
		font-weight: 700;
		color: var(--text-primary);
		text-transform: uppercase;
		letter-spacing: 1px;
		text-decoration: none;
	}
	.main-nav {
		display: flex;
		gap: 2em;
	}
	.main-nav :global(a) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		color: var(--text-muted);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		padding-bottom: 4px;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}
	.main-nav :global(a:hover),
	.main-nav :global(a.active) {
		color: var(--text-primary);
		border-bottom-color: var(--accent-green);
	}
	.action-link a {
		font-family: var(--font-mono);
		font-size: 0.9em;
		color: var(--text-muted);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 0.5em;
		transition: color 0.2s ease;
	}
	.action-link a:hover {
		color: var(--accent-green);
	}
	.arrow {
		color: var(--accent-green);
		font-weight: 700;
	}

	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			gap: 1.5em;
		}
	}
</style>
